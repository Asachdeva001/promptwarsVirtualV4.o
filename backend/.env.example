# StadiumOS environment configuration
# Duplicate this file as '.env' in this directory and fill in your keys.

# [REQUIRED] Google Gemini API key
# Used for Operations Copilot and natural language query systems.
GEMINI_API_KEY=your_gemini_api_key_here

# [REQUIRED] Firebase Service Account Key Path
# Absolute path to your Firebase Admin SDK service account JSON credentials file.
# Used by database.py to initialize the Firestore connection.
FIREBASE_SERVICE_ACCOUNT_KEY=/absolute/path/to/your/firebase-adminsdk.json

# [OPTIONAL] Frontend URL for CORS
# The production URL of your frontend application to allow cross-origin requests.
# Localhost ports (3000, 3001, 5173) are already whitelisted by default.
FRONTEND_URL=https://my-stadium-frontend.app
