# StadiumOS Root Environment Configuration
# This file serves as a reference for all environment variables used across the project.
# You can duplicate this file as '.env' in the root directory if you are using Docker Compose,
# or split these variables into backend/.env and frontend/.env respectively.

# ---------------------------------------------------------
# BACKEND CONFIGURATION
# ---------------------------------------------------------

# [REQUIRED] Google Gemini API key
# Used for Operations Copilot and natural language query systems.
GEMINI_API_KEY=your_gemini_api_key_here

# [REQUIRED] Firebase Service Account Key Path
# Absolute path to your Firebase Admin SDK service account JSON credentials file.
# Used by backend/app/database.py to initialize the Firestore connection.
FIREBASE_SERVICE_ACCOUNT_KEY=/absolute/path/to/your/firebase-adminsdk.json

# [OPTIONAL] Frontend URL for CORS
# The production URL of your frontend application to allow cross-origin requests.
# Localhost ports (3000, 3001, 5173) are already whitelisted by default.
FRONTEND_URL=http://localhost:3000


# ---------------------------------------------------------
# FRONTEND CONFIGURATION
# ---------------------------------------------------------

# [OPTIONAL] Backend API URL
# Points to the StadiumOS FastAPI backend. Defaults to http://localhost:8000 if not provided.
VITE_API_URL=http://localhost:8000
